model Project {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String               @map("company_id") @db.Uuid
  name                 String
  code                 String?
  type                 ProjectType?
  location             String?
  status               ProjectStatus        @default(draft)
  startDate            DateTime?            @map("start_date") @db.Date
  targetCompletionDate DateTime?            @map("target_completion_date") @db.Date
  completedAt          DateTime?            @map("completed_at") @db.Timestamptz(6)
  description          String?
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?            @map("deleted_at") @db.Timestamptz(6)
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  phases               ProjectPhase[]
  milestones           ProjectMilestone[]
  documents            ProjectDocument[]
  updates              ProjectUpdate[]
  issues               ProjectIssue[]
  assignments          ProjectAssignment[]
  budget               ProjectBudget?
  workers              ProjectWorker[]
  payrollRuns          ProjectPayrollRun[]

  @@index([companyId], map: "projects_company_id_idx")
  @@index([companyId, status], map: "projects_company_status_idx")
  @@index([deletedAt], map: "projects_deleted_at_idx")
  @@map("projects")
}
