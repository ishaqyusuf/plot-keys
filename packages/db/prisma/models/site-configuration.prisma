model SiteConfiguration {
  id          String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String                  @map("company_id") @db.Uuid
  templateKey String                  @map("template_key")
  name        String
  status      SiteConfigurationStatus @default(draft)
  subdomain   String?
  themeJson   Json                    @default("{}") @map("theme_json")
  contentJson Json                    @default("{}") @map("content_json")
  version     Int                     @default(1)
  publishedAt DateTime?               @map("published_at") @db.Timestamptz(6)
  createdById String?                 @map("created_by_id")
  updatedById String?                 @map("updated_by_id")
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?               @map("deleted_at") @db.Timestamptz(6)
  company     Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User?                   @relation("SiteConfigurationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?                   @relation("SiteConfigurationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([companyId], map: "site_configurations_company_id_idx")
  @@index([companyId, status], map: "site_configurations_company_status_idx")
  @@index([templateKey], map: "site_configurations_template_key_idx")
  @@index([deletedAt], map: "site_configurations_deleted_at_idx")
  @@map("site_configurations")
}
