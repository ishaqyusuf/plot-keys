model Company {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug               String
  name               String
  market             String?
  logoUrl            String?                 @map("logo_url")
  planTier           CompanyPlanTier         @default(starter) @map("plan_tier")
  planStatus         CompanyPlanStatus       @default(active) @map("plan_status")
  planStartedAt      DateTime?               @map("plan_started_at") @db.Timestamptz(6)
  planEndsAt         DateTime?               @map("plan_ends_at") @db.Timestamptz(6)
  isActive           Boolean                 @default(true) @map("is_active")
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?               @map("deleted_at") @db.Timestamptz(6)
  memberships        Membership[]
  siteConfigurations SiteConfiguration[]
  website            Website?
  tenantDomains      TenantDomain[]
  properties         Property[]
  agents             Agent[]
  templateLicenses   TenantTemplateLicense[]
  billingLineItems   BillingLineItem[]
  leads              Lead[]
  appointments       Appointment[]
  stockImageLicenses TenantStockImageLicense[]
  aiUsageLogs        AiUsageLog[]
  aiCreditLedger     AiCreditLedger[]
  analyticsEvents    AnalyticsEvent[]
  teamInvites        TeamInvite[]
  notifications      Notification[]
  customers          Customer[]
  departments        Department[]
  employees          Employee[]
  payrollEntries     PayrollEntry[]
  notificationPreferences NotificationPreference[]
  integration         CompanyIntegration?
  projects            Project[]

  @@index([slug], map: "companies_slug_idx")
  @@index([planTier], map: "companies_plan_tier_idx")
  @@index([planStatus], map: "companies_plan_status_idx")
  @@index([deletedAt], map: "companies_deleted_at_idx")
  @@map("companies")
}

