model TenantOnboarding {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @unique @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core identity set during signup
  companyName String    @map("company_name")
  subdomain   String

  // Step 1: Business Identity
  tagline        String? @map("tagline")
  businessType   String? @map("business_type")
  primaryGoal    String? @map("primary_goal")

  // Step 2: Market Focus
  locations      String[] @map("locations")
  propertyTypes  String[] @map("property_types")
  targetAudience String?  @map("target_audience")

  // Step 3: Brand Style
  tone               String? @map("tone")
  stylePreference    String? @map("style_preference")
  preferredColorHint String? @map("preferred_color_hint")

  // Step 4: Contact And Operations
  phone         String? @map("phone")
  contactEmail  String? @map("contact_email")
  whatsapp      String? @map("whatsapp")
  officeAddress String? @map("office_address")

  // Step 5: Content Readiness
  hasLogo            Boolean @default(false) @map("has_logo")
  hasListings        Boolean @default(false) @map("has_listings")
  hasExistingContent Boolean @default(false) @map("has_existing_content")
  hasAgents          Boolean @default(false) @map("has_agents")
  hasProjects        Boolean @default(false) @map("has_projects")
  hasTestimonials    Boolean @default(false) @map("has_testimonials")
  hasBlogContent     Boolean @default(false) @map("has_blog_content")

  // Final step fields (market = primary market area, templateKey = chosen template)
  market      String?
  templateKey String? @map("template_key")

  currentStep String    @default("business-identity") @map("current_step")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId], map: "tenant_onboardings_user_id_idx")
  @@index([completedAt], map: "tenant_onboardings_completed_at_idx")

  @@map("tenant_onboardings")
}
