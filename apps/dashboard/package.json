{
  "name": "@plotkeys/dashboard",
  "private": true,
  "scripts": {
    "build": "node ../../scripts/with-workspace-env.mjs next build --turbopack",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "node ../../scripts/with-workspace-env.mjs PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-3901} TZ=UTC portless app.plotkeys next dev --turbopack",
    "dev:portless": "node ../../scripts/with-workspace-env.mjs portless app.plotkeys next dev --turbopack",
    "lint": "biome check .",
    "start": "node ../../scripts/with-workspace-env.mjs next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@plotkeys/api": "workspace:*",
    "@plotkeys/auth": "workspace:*",
    "@plotkeys/db": "workspace:*",
    "@plotkeys/notifications": "workspace:*",
    "@plotkeys/notifications-react": "workspace:*",
    "@plotkeys/platform-integrations": "workspace:*",
    "@plotkeys/section-registry": "workspace:*",
    "@plotkeys/ui": "workspace:*",
    "@plotkeys/utils": "workspace:*",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@trpc/tanstack-react-query": "^11.0.0",
    "lucide-react": "^0.577.0",
    "next": "^16.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "superjson": "^2.2.2",
    "zod": "^3.23.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@plotkeys/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.0"
  }
}
