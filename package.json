{
  "name": "plotkeys",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "db:down": "docker compose down",
    "db:generate": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/plotkeys bun run --cwd packages/db db:generate",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/plotkeys bun run --cwd packages/db db:migrate",
    "db:migrate:deploy": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/plotkeys bun run --cwd packages/db db:migrate:deploy",
    "db:studio": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/plotkeys bun run --cwd packages/db db:studio",
    "db:drizzle:studio": "DATABASE_URL=postgres://postgres:postgres@localhost:5432/plotkeys bun run --cwd packages/db db:drizzle:studio",
    "db:up": "docker compose up -d postgres",
    "dev": "turbo dev --parallel",
    "dev:api": "turbo dev --filter=@plotkeys/api",
    "dev:dashboard": "turbo dev --filter=@plotkeys/dashboard",
    "dev:website": "turbo dev --filter=@plotkeys/website",
    "dev:tenant-site": "turbo dev --filter=@plotkeys/tenant-site",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
