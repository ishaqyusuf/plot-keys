{
  "name": "plotkeys",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "dev:api": "turbo dev --filter=@plotkeys/api",
    "dev:dashboard": "turbo dev --filter=@plotkeys/dashboard",
    "dev:website": "turbo dev --filter=@plotkeys/website",
    "dev:websites": "turbo dev --filter=@plotkeys/websites",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "turbo": "^2.5.0",
    "typescript": "^5.9.0"
  }
}
